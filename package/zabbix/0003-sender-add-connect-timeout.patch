From dd9196c4227d48fcaeb8d8a795dd0c19f75974d6 Mon Sep 17 00:00:00 2001
From: Ksenia Safonova <ksafonova@dlink.ru>
Date: Wed, 7 Apr 2021 12:21:59 +0300
Subject: [#44956] sender: add connect timeout
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit
Patch-from-hash: origin/master
Patch-repo: 
Patch-branch: master
Patch-version: 1

Добавила настраиваемый таймаут подключения к серверу для zabbix_sender.

Signed-off-by: Ksenia Safonova <ksafonova@dlink.ru>
---
 include/comms.h                   |  3 +++
 src/zabbix_sender/zabbix_sender.c | 26 ++++++++++++++++++++++++++
 2 files changed, 29 insertions(+)

diff --git a/include/comms.h b/include/comms.h
index 590df44..caf9700 100644
--- a/include/comms.h
+++ b/include/comms.h
@@ -137,6 +137,9 @@ int	zbx_tcp_check_security(zbx_sock_t *s, const char *ip_list, int allow_if_empt
 
 #define ZBX_DEFAULT_AGENT_PORT_STR	"10050"
 #define ZBX_DEFAULT_SERVER_PORT_STR	"10051"
+#ifdef DLINK_SOFTWARE
+#define ZBX_DEFAULT_CONNECT_TIMEOUT_STR	"60"
+#endif
 
 int	zbx_send_response_ext(zbx_sock_t *sock, int result, const char *info, int protocol, int timeout);
 
diff --git a/src/zabbix_sender/zabbix_sender.c b/src/zabbix_sender/zabbix_sender.c
index d05166d..a3ad0ae 100644
--- a/src/zabbix_sender/zabbix_sender.c
+++ b/src/zabbix_sender/zabbix_sender.c
@@ -29,7 +29,11 @@
 const char	*progname = NULL;
 const char	title_message[] = "Zabbix Sender";
 const char	syslog_app_name[] = "zabbix_sender";
+#ifdef DLINK_SOFTWARE
+const char	usage_message[] = "[-Vhv] {[-zptsI] -ko | [-zptI] -T -i <file> -r} [-c <file>]";
+#else
 const char	usage_message[] = "[-Vhv] {[-zpsI] -ko | [-zpI] -T -i <file> -r} [-c <file>]";
+#endif
 
 const char	*help_message[] = {
 	"Options:",
@@ -37,6 +41,9 @@ const char	*help_message[] = {
 	"",
 	"  -z --zabbix-server <server>          Hostname or IP address of Zabbix server",
 	"  -p --port <server port>              Specify port number of server trapper running on the server. Default is " ZBX_DEFAULT_SERVER_PORT_STR,
+#ifdef DLINK_SOFTWARE
+	"  -t --timeout <timeout>               Specify timeout in seconds to connect to Zabbix server. Default is " ZBX_DEFAULT_CONNECT_TIMEOUT_STR,
+#endif
 	"  -s --host <hostname>                 Specify host name. Host IP address and DNS name will not work",
 	"  -I --source-address <IP address>     Specify source IP address",
 	"",
@@ -68,6 +75,9 @@ static struct zbx_option	longopts[] =
 	{"config",		1,	NULL,	'c'},
 	{"zabbix-server",	1,	NULL,	'z'},
 	{"port",		1,	NULL,	'p'},
+#ifdef DLINK_SOFTWARE
+	{"timeout",		1,	NULL,	't'},
+#endif
 	{"host",		1,	NULL,	's'},
 	{"source-address",	1,	NULL,	'I'},
 	{"key",			1,	NULL,	'k'},
@@ -82,7 +92,11 @@ static struct zbx_option	longopts[] =
 };
 
 /* short options */
+#ifdef DLINK_SOFTWARE
+static char	shortopts[] = "c:I:z:p:t:s:k:o:Ti:rvhV";
+#else
 static char	shortopts[] = "c:I:z:p:s:k:o:Ti:rvhV";
+#endif
 
 /* end of COMMAND LINE OPTIONS */
 
@@ -98,6 +112,9 @@ unsigned short	ZABBIX_SERVER_PORT = 0;
 static char	*ZABBIX_HOSTNAME = NULL;
 static char	*ZABBIX_KEY = NULL;
 static char	*ZABBIX_KEY_VALUE = NULL;
+#ifdef DLINK_SOFTWARE
+unsigned short	ZABBIX_CONNECT_TIMEOUT = 60;
+#endif
 
 #if !defined(_WINDOWS)
 static void	send_signal_handler(int sig)
@@ -311,7 +328,11 @@ static	ZBX_THREAD_ENTRY(send_value, args)
 	signal(SIGALRM, send_signal_handler);
 #endif
 
+#ifdef DLINK_SOFTWARE
+	if (SUCCEED == (tcp_ret = zbx_tcp_connect(&sock, CONFIG_SOURCE_IP, sentdval_args->server, sentdval_args->port, ZABBIX_CONNECT_TIMEOUT)))
+#else
 	if (SUCCEED == (tcp_ret = zbx_tcp_connect(&sock, CONFIG_SOURCE_IP, sentdval_args->server, sentdval_args->port, GET_SENDER_TIMEOUT)))
+#endif
 	{
 		if (SUCCEED == (tcp_ret = zbx_tcp_send(&sock, sentdval_args->json.buffer)))
 		{
@@ -444,6 +465,11 @@ static void	parse_commandline(int argc, char **argv)
 			case 'r':
 				REAL_TIME = 1;
 				break;
+#ifdef DLINK_SOFTWARE
+			case 't':
+				ZABBIX_CONNECT_TIMEOUT = (unsigned short)atoi(zbx_optarg);
+				break;
+#endif
 			case 'v':
 				if (LOG_LEVEL_WARNING > CONFIG_LOG_LEVEL)
 					CONFIG_LOG_LEVEL = LOG_LEVEL_WARNING;
-- 
2.20.1

