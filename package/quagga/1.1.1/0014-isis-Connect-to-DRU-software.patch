From 2b440787853cb44bf05d417d0869af925d12a075 Mon Sep 17 00:00:00 2001
From: farisey <anikulin@dlink.ru>
Date: Wed, 17 Jul 2019 16:47:44 +0300
Subject: [PATCH] isis: Connect to DRU software.

Service connect.
---
 isisd/isis_main.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/isisd/isis_main.c b/isisd/isis_main.c
index 1dda43bc..cd45ec67 100644
--- a/isisd/isis_main.c
+++ b/isisd/isis_main.c
@@ -53,6 +53,10 @@
 #include "isisd/isis_tlv.h"
 #include "isisd/isis_te.h"
 
+#ifdef DLINK_SOFTWARE
+#include <d-link/d_service_notify.h>
+#endif
+
 /* Default configuration file name */
 #define ISISD_DEFAULT_CONFIG "isisd.conf"
 /* Default vty port */
@@ -371,6 +375,10 @@ main (int argc, char **argv, char **envp)
   /* Print banner. */
   zlog_notice ("Quagga-ISISd %s starting: vty@%d", QUAGGA_VERSION, vty_port);
 
+#ifdef DLINK_SOFTWARE
+	dlink_service_connect(0);
+#endif
+
   /* Start finite state machine. */
   while (thread_fetch (master, &thread))
     thread_call (&thread);
